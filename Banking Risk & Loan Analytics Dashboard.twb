      <aliases enabled='yes' />
      <column caption='Bank Name' datatype='string' name='[BankName]' role='dimension' type='nominal' />
      <column caption='Credit Score Band' datatype='string' name='[Calculation_1367543462850561]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [CreditScore] &lt; 580 THEN &quot;Poor&quot;&#13;&#10;ELSEIF [CreditScore] &lt; 670 THEN &quot;Fair&quot;&#13;&#10;ELSEIF [CreditScore] &lt; 740 THEN &quot;Good&quot;&#13;&#10;ELSEIF [CreditScore] &lt; 800 THEN &quot;Very Good&quot;&#13;&#10;ELSE &quot;Excellent&quot;&#13;&#10;END' />
      </column>
      <column caption='Age Group' datatype='string' name='[Calculation_1367543462993922]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Age] &lt;= 25 THEN &quot;18-25&quot;&#13;&#10;ELSEIF [Age] &lt;= 35 THEN &quot;26-35&quot;&#13;&#10;ELSEIF [Age] &lt;= 45 THEN &quot;36-45&quot;&#13;&#10;ELSEIF [Age] &lt;= 55 THEN &quot;46-55&quot;&#13;&#10;ELSE &quot;56+&quot;&#13;&#10;END' />
      </column>
      <column caption='Defaut rate' datatype='real' default-format='p0.00%' name='[Calculation_1367543481016323]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Default]) / COUNT([LoanID])' />
      </column>
      <column caption='Avg Loan Amount per Bank (LOD)' datatype='real' name='[Calculation_1367543637929988]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED [BankName] : AVG([LoanAmount]) }' />
      </column>
      <column caption='Average Credit Score by State (LOD)' datatype='real' name='[Calculation_1367543640305669]' role='measure' type='quantitative'>
